<mujoco model="ur5e_push_t">
  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast"/>

  <include file="model/universal_robots_ur5e/ur5e.xml"/>

  <statistic center="0 0 0.4" extent="1.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    
    <!-- Table texture -->
    <texture name="table_tex" type="2d" builtin="flat" rgb1="0.9 0.9 0.9" width="512" height="512"/>
    <material name="table_mat" texture="table_tex"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <!-- Mocap Site for IO control (Must be child of worldbody) -->
    <body name="mocap_target" pos="0.5 0 0.5" mocap="true">
        <geom type="sphere" size="0.01" rgba="0 1 0 0.9" contype="0" conaffinity="0" group="1"/>
    </body>

    <!-- White Table -->
    <body name="table" pos="0.4 0 0.2">
        <geom type="box" size="0.8 1.0 0.2" material="table_mat"
              contype="1" conaffinity="1"
              solref="0.005 1" solimp="0.99 0.999 0.001" friction="0.5 0.1 0.1"/>
    </body>

    <!-- Front Camera -->
    <camera name="front_camera" pos="1.2 0 1.6" xyaxes="0 1 0 -0.866 0 0.5" fovy="60"/>

    <!-- Top-Down Camera (for mouse control mapping) -->
    <camera name="top_camera" pos="0.5 0 2.0" xyaxes="1 0 0 0 1 0" fovy="60"/>

    <!-- Target T-shape area (Visual only, black lines) -->
    <body name="target" pos="0.5 0 0.401">
        <geom type="box" size="0.02 0.1 0.001" pos="0 0 0" rgba="0 0 0 1" contype="0" conaffinity="0"/>
        <geom type="box" size="0.08 0.02 0.001" pos="0 0.08 0" rgba="0 0 0 1" contype="0" conaffinity="0"/>
    </body>

    <!-- T-block to be pushed (Red) -->
    <body name="t_block" pos="0.5 -0.2 0.42">
        <freejoint name="t_block_joint"/>
        <geom type="box" size="0.02 0.1 0.02" pos="0 0 0" rgba="0.8 0.2 0.2 1" mass="1.0"
              friction="0.8 0.1 0.1" contype="1" conaffinity="1"
              solref="0.005 1" solimp="0.99 0.999 0.001"/>
        <geom type="box" size="0.08 0.02 0.02" pos="0 0.08 0" rgba="0.8 0.2 0.2 1" mass="1.0"
              friction="0.8 0.1 0.1" contype="1" conaffinity="1"
              solref="0.005 1" solimp="0.99 0.999 0.001"/>
    </body>

  </worldbody>

  <equality>
    <weld body1="mocap_target" body2="pusher_tool" relpose="0 0 -0.1 1 0 0 0" solref="0.01 1" solimp="0.99 0.999 0.001"/>
  </equality>

</mujoco>
